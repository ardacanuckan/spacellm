{
  "name": "spacellm-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "SpaceLLM — the open framework for radiation-tolerant transformer training and inference in space.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.5.0",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter web build",
    "lint": "pnpm --filter web lint",
    "test": "pnpm --filter web test",
    "typecheck": "pnpm --filter web typecheck",
    "format": "pnpm --filter web format",
    "py:install": "uv sync --all-extras --all-packages",
    "py:test": "uv run --package spacellm pytest packages/spacellm",
    "py:lint": "uv run ruff check packages/spacellm",
    "py:format": "uv run ruff format packages/spacellm",
    "py:typecheck": "uv run mypy packages/spacellm/src",
    "docs:serve": "uv run --package spacellm-docs mkdocs serve -f packages/docs/mkdocs.yml",
    "docs:build": "uv run --package spacellm-docs mkdocs build -f packages/docs/mkdocs.yml"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15"
  }
}
